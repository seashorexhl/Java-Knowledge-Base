-        int last = -1;
-        int sum = 0;
-
-        for (int i = 0; i < n; i++) {
-            last = getMinEleIdx(res[i], last);
-            sum += res[i][last];
-        }
-
-        return sum;
-    }
-    /*  根据规则 挑选  */
-    public static int getMinEleIdx(int[] arr, int excludeIdx) {

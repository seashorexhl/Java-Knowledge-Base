-                if (dist[u] + w < dist[v]) {
-                    dist[v] = dist[u] + w;
-                }
-            }
-        }
-
-        // 找出所有电脑中最长的感染时间
-        int maxWait = 0;
-        for (int i = 0; i < N; i++) {
-            // 如果有电脑的感染时间仍为无穷大，表示该电脑不可被感染，返回-1
-            if (dist[i] == INF) return -1;
-            // 更新最长的感染时间

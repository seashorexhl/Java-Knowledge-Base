-
-        for (int i = 0; i < arr.length; i++) {
-            if (i == excludeIdx) continue;
-
-            if (arr[i] <= minEleVal) {
-                minEleVal = arr[i];
-                minEleIdx = i;
-            }
-        }
-        return minEleIdx;
-    }
